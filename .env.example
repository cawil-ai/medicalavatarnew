# Copy to .env and fill in real values. NEVER commit .env — it holds live secrets.
# Production deploys: set these in the hosting provider (Render) environment instead.

# Appwrite
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_DATABASE_ID=health_ai_db

# Appwrite collection ids
VITE_COLLECTION_HEART=heart_logs
VITE_COLLECTION_SLEEP=sleep_logs
VITE_COLLECTION_CALORIES=calories_logs
VITE_COLLECTION_HYDRATION=hydration_logs
VITE_COLLECTION_STEPS=steps_logs
VITE_COLLECTION_JOURNAL=journal_logs
VITE_COLLECTION_MEDITATION=meditation_logs
VITE_COLLECTION_MOOD=mood_logs
VITE_COLLECTION_FEMALE_HEALTH=female_health_logs
VITE_COLLECTION_USERS=users
VITE_COLLECTION_FALL_EVENTS=fall_detection_logs
VITE_COLLECTION_EMERGENCY_CONTACTS=emergency_contacts

# Novu (fall-alert emails) — see docs/FALL_DETECTION_ARCHITECTURE.md §7 security note
VITE_NOVU_API_KEY=your-novu-api-key
